    <script id="jsonLdBreadcump" type="application/ld+json"></script>

    <script>
            function continueWithNextIdp(notification) {
                if (notification.isNotDisplayed() || notification.isSkippedMoment()) {
                    window._skippedOneTap = true;
                }
            }

            function handleCredentialResponse(response) {
                var decodedToken = jwt_decode(response.credential);

                loginUserGoogle({
                    facebook: true,
                    displayName: decodedToken.name,
                    email: decodedToken.email,
                    photoUrl: decodedToken.picture
                        ? decodedToken.picture
                        : '/img/avatar.svg'
                });
            }

        function loginUserGoogle(options) {

            var currentUrl = new URL(window.location.href);

            var apiUrl = new URL([
                currentUrl.protocol, '', currentUrl.host, 'user/logarUsuario'
            ].join('/'));

            apiUrl.searchParams.set('flgFB', true);
            apiUrl.searchParams.set('emailUsu', options.email || '');
            apiUrl.searchParams.set('pwdUsu', options.password || '');
            apiUrl.searchParams.set('telUsuario', options.phone || '');
            apiUrl.searchParams.set('nomeUsuario', options.displayName || '');

            $.getJSON(apiUrl, function (response) {
                if (!response.erro && response.unico) {
                    createUserCookie({
                        avatar: options.photoUrl || '/img/avatar.svg',
                        clienteId: response.unico.cliente_id,
                        clienteEmail: response.unico.email,
                        name: response.unico.displayName,
                        favoritos: response.unico.listImoveisFavoritos
                    });

                    redirectUser();
                } else {
                    $('.feedback').show()
                        .html(response.mensagem);
                }
            })
                .fail(function (err) {
                    $('.feedback').show()
                        .html(err.message);
                })
                .always(function () {
                    $('.btn-confirmar').prop('disabled', false);
                });
        }

        /**
        * Grava as informações do usuário no localStorage e cria um cookie
        */
        function createUserCookie(user) {
            window.setCookie('NetCli', JSON.stringify(user), 365);
            window.setCookie('cid', user.clienteId, 365);
            window.setCookie('usuarioLogado', 'true', 365);
            window.localStorage.setItem('usuarioLogado', 'true');
            window.localStorage.setItem('NetCli', JSON.stringify(user));
            window.localStorage.setItem('listImovel', user.favoritos || '');
        }

        /**
         * Redireciona o usuário para a próxima página
        */
        function redirectUser() {
            var url = new URL(window.location.href);
            var next = url.searchParams.get('next');
            var redirectUrl = '/';
            if (next) {
                redirectUrl = decodeURIComponent(next);
            }
            window.location.href = redirectUrl;
        }
    </script>

</body>

</html>
