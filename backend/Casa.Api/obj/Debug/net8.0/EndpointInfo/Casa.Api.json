      "PropertyListingUpsertRequest": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "nullable": true
          },
          "category": {
            "type": "string",
            "nullable": true
          },
          "source": {
            "$ref": "#/components/schemas/PropertySource"
          },
          "originalUrl": {
            "type": "string",
            "nullable": true
          },
