{
  "manifest_version": 3,
  "name": "Casa Importador",
  "description": "Importa anuncios imobiliarios para o sistema Casa rodando localmente.",
  "version": "0.1.0",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "http://localhost/*",
    "https://localhost/*",
    "http://127.0.0.1/*",
    "https://127.0.0.1/*",
    "https://viacep.com.br/*",
    "https://nominatim.openstreetmap.org/*",
    "https://www.quintoandar.com.br/*",
    "https://www.vivareal.com.br/*",
    "https://www.zapimoveis.com.br/*",
    "https://www.imovelweb.com.br/*",
    "https://www.netimoveis.com/*",
    "https://painel.netimoveis.com/*",
    "https://fotosimoveis.blob.core.windows.net/*",
    "https://www.olx.com.br/*",
    "https://*.olx.com.br/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "action": {
    "default_title": "Casa Importador",
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "32": "assets/icons/icon-32.png",
      "48": "assets/icons/icon-48.png"
    }
  },
  "options_page": "src/options/options.html",
  "content_scripts": [
    {
      "matches": [
        "https://www.quintoandar.com.br/*",
        "https://www.vivareal.com.br/*",
        "https://www.zapimoveis.com.br/*",
        "https://www.imovelweb.com.br/*",
        "https://www.netimoveis.com/*",
        "https://www.olx.com.br/*",
        "https://*.olx.com.br/*"
      ],
      "js": [
        "src/content/extractors.js",
        "src/content/content-script.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
